<?xml version="1.0" encoding="utf-8"?>
<!--item_order_notification.xml-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="3dp"
    card_view:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgMenu"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bakso"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User ID"
                android:textStyle="bold"
                android:textColor="#7A2E2E"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bakso Keju"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="@color/setting_text"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24 Juni 2026"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvAddon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Extra Keju"
                android:textColor="@color/text_3"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah : 2"
                android:textColor="@color/text_3"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 50.000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#D32F2F"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnOrderDetail"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Lihat Detail"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#E53935"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>