<!--item_order_notification.xml-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_notification_page"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/imgMenu"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:src="@drawable/bakso"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/tvId"
            android:textStyle="bold"
            android:text="Nigga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvNama"
            android:textStyle="bold"
            android:text="Bakso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!--tvDate menggunakan created_at dari data order-->
        <TextView
            android:id="@+id/tvDate"
            android:text="Senin, 24 Januari 2025, 09.00"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvAddon"
            android:text="Addon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvQty"
            android:text="Jumlah: 1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTotal"
            android:textStyle="bold"
            android:text="Rp 10000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnOrderDetail"
            android:text="Lihat Orderan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF2E2E"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>