<?xml version="1.0" encoding="utf-8"?>
<!--item_order_notification.xml-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="3dp"
    card_view:cardBackgroundColor="@color/setting_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgMenu"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bakso" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User ID"
                android:textColor="@color/primary_title"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!--tvNama menampilkan nama menu pertama yang ada di item di collection orders-->
            <TextView
                android:id="@+id/tvNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Bakso Keju"
                android:textColor="@color/setting_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!--tvNamaUser menampilkan nama user yang ada di orders-->
            <TextView
                android:id="@+id/tvNamaUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Nama User"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="24 Juni 2026"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvPickupType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dine In"
                android:textColor="@color/primary_title"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="@drawable/bg_setting_item"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tvAddon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Extra Keju"
                android:textColor="@color/text_3"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Jumlah : 2"
                android:textColor="@color/text_3" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Rp 50.000"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!--Hanya muncul jika jumlah menu yang diorder lebih dari 1-->
            <TextView
                android:id="@+id/tvOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="dan 2 menu lainnya"
                android:textColor="@color/text_3"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnOrderDetail"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#E53935"
                android:text="Lihat Detail"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>