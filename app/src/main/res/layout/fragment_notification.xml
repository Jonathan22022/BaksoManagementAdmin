<?xml version="1.0" encoding="utf-8"?>
<!--fragment_notification.xml-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daftar Orderan"
            android:textStyle="bold"
            android:textSize="22sp"
            android:background="@drawable/bg_dashboard_title"
            android:textColor="@color/primary_title"
            android:gravity="center"
            android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <!-- FILTER TANGGAL -->
        <EditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_dashboard_field"
            android:drawableEnd="@drawable/ic_calendar"
            android:focusable="false"
            android:hint="Pilih Tanggal"
            android:paddingHorizontal="16dp"
            android:textColor="@color/setting_text"
            android:textColorHint="@color/setting_text"
            android:alpha="0.9" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/setting_card"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNotification"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>