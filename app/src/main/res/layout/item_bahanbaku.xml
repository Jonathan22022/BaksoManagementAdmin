<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_favourite_card"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgBahanBaku"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/bakso"/>

    <LinearLayout
        android:layout_marginStart="12dp"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvBahanBakuName"
            android:text="Bakso Keju"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#8B2E2E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvBahanBakuHarga"
            android:text="Bakso Keju"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#8B2E2E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvBahanBakuBerat"
            android:text="Bakso Keju"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#8B2E2E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                android:layout_marginEnd="8dp"/>

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>