<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_page">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bahan Baku"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/primary_title"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_menu_title"/>

    <!-- Button Tambah -->
    <Button
        android:id="@+id/btnTambahBahan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tambah Bahan Baku"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/red"/>

    <!-- List -->
    <!-- Header Table -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@color/setting_card"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Gambar"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

                <TextView
                    android:layout_width="150dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Nama"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Harga"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Berat"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Satuan"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Edit"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Hapus"
                    android:textStyle="bold"
                    android:textColor="@color/setting_text"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBahanBaku"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"/>

        </LinearLayout>

    </HorizontalScrollView>
</LinearLayout>