<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="80dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="@drawable/bg_table_row">

    <ImageView
        android:id="@+id/imgMenu"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:padding="6dp"
        android:scaleType="centerCrop"/>

    <TextView
        android:id="@+id/tvMenuName"
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:textColor="@color/setting_text"/>

    <TextView
        android:id="@+id/tvMenuDesc"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingHorizontal="8dp"
        android:textColor="@color/setting_text"/>

    <TextView
        android:id="@+id/tvMenuHarga"
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="@color/setting_text"/>

    <TextView
        android:id="@+id/tvStockStatus"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:textColor="@color/text_4"
        android:maxLines="3"/>

    <TextView
        android:id="@+id/tvBahanDibutuhkan"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:textColor="@color/setting_text"
        android:maxLines="5"/>

    <ImageView
        android:id="@+id/btnEdit"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:padding="18dp"
        android:src="@drawable/ic_edit"
        app:tint="@color/bottom_nav_active"/>

    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:padding="18dp"
        android:src="@drawable/ic_delete"
        app:tint="@color/text_4"/>

</LinearLayout>